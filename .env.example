DISCORD_TOKEN=paste_your_bot_token_here
# Optional but recommended during setup: paste your Discord server ID here for fast guild-only slash command sync
DISCORD_GUILD_ID=
# Optional: set to 1 once to delete stale global slash commands before guild sync
DISCORD_CLEAR_GLOBAL_COMMANDS=0
BGA_POLL_SECONDS=15
BGA_DB_PATH=bga_bot.db
BGA_WS_URL=wss://ws-x1.boardgamearena.com/connection/websocket
# Optional: set to 1 to re-enable the tableinfos HTTP fallback for end-of-game detection
BGA_ENABLE_TABLEINFOS_FALLBACK=0
LOG_LEVEL=INFO
BOT_LANG=EN
